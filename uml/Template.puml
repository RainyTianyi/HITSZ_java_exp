}

class NormalAction {
    + NormalAction(String, HeroAircraft, List<EnemyAircraft>, List<BaseBullet>, List<BaseBullet>, List<BaseItem>, DaoImpl, JPanel)
    # initParameters() : void
    # EnemySpawnAction() : void
